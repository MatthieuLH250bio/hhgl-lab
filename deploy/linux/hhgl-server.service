[Unit]
Description=HHGL Lab — Serveur FastAPI
After=network.target postgresql.service
Requires=postgresql.service

[Service]
Type=exec
User=__USER__
WorkingDirectory=__INSTALL_DIR__/server
EnvironmentFile=__INSTALL_DIR__/server/.env
ExecStart=__INSTALL_DIR__/server/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
